# Secrets — never bake into the image
.env
.env.*
!.env.example

# VCS / editor / OS
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store

# Python local state
.venv
venv
__pycache__
**/__pycache__
*.py[cod]
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# Local data / uploads (mount these at runtime instead of baking)
uploads/*
!uploads/.gitkeep

# Docs / samples not needed in the runtime image
README.md
sample.png
evaluation/

# Docker artifacts
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml
